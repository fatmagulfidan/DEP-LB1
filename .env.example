# Environment Configuration for Weather Dashboard
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control - it should only contain placeholders

# Node Environment (development, production, test)
NODE_ENV=production

# Backend Configuration
BACKEND_PORT=3000

# Frontend Configuration
FRONTEND_PORT=8080

# Database Configuration
# For Docker Compose, use 'db' as the hostname (the service name in docker-compose.yml)
# For local development, use 'localhost'
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=weather_db

# OpenWeatherMap API
# Get your free API key from: https://openweathermap.org/api
# Keep this secret - never commit your actual key to version control
OPENWEATHER_API_KEY=your_api_key_here
